PAPER_CAPITAL_USD=1000
DEPLOY_FRACTION=0.60
POLL_INTERVAL_SECS=10
N_CONCURRENT_PAIRS=10
DB_PATH=/data/paper.db
MAKER_EXIT_TIMEOUT_SECS=20
Z_ENTRY_THRESHOLD=2.5
Z_ROLLING_WINDOW=360
Z_MIN_LIVE_OBS=30
STOP_LOSS_BUFFER_MULT=1.05
LOSS_STREAK_THRESHOLD=2
LOSS_STREAK_COOLDOWN_HOURS=24

# ── LIVE TRADING (real money - leave LIVE_TRADING unset/false until ready) ──
LIVE_TRADING=false
LIVE_EXCHANGES=
PER_EXCHANGE_CAPITAL_USD=20
KILL_SWITCH=false
LEG_FILL_RETRY_SECS=5

# Per-exchange credentials - only needed once LIVE_TRADING=true and the
# exchange is in LIVE_EXCHANGES. Set these as actual secrets in Railway's
# Variables tab, never commit real values here.
ASTER_API_KEY=
ASTER_API_SECRET=

# Hyperliquid - a dedicated trade-only API wallet (app.hyperliquid.xyz/API),
# NOT your main wallet's key - it should not be able to withdraw.
HL_API_WALLET_PRIVATE_KEY=
HL_ACCOUNT_ADDRESS=

# Pacifica - a dedicated agent wallet (app.pacifica.fi/apikey), same
# non-withdrawal principle as HL's API wallet.
PACIFICA_AGENT_PRIVATE_KEY=
PACIFICA_ACCOUNT_ADDRESS=

# Ostium - uses delegation: OSTIUM_WALLET_PRIVATE_KEY is the DELEGATE signer
# (needs its own ETH on Arbitrum for gas, regardless of delegation) that has
# already been approved on-chain/via Ostium's UI to trade on behalf of
# OSTIUM_ACCOUNT_ADDRESS (the main account that actually holds the USDC
# collateral). If that approval was never done, trades fail at the contract
# level no matter what's set here.
OSTIUM_WALLET_PRIVATE_KEY=
OSTIUM_ACCOUNT_ADDRESS=
OSTIUM_RPC_URL=
OSTIUM_LEVERAGE=2
