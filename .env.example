PAPER_CAPITAL_USD=1000
DEPLOY_FRACTION=0.60
POLL_INTERVAL_SECS=10
N_CONCURRENT_PAIRS=10
DB_PATH=/data/paper.db
MAKER_EXIT_TIMEOUT_SECS=20
Z_ENTRY_THRESHOLD=2.5
Z_ROLLING_WINDOW=360
Z_MIN_LIVE_OBS=30
STOP_LOSS_BUFFER_MULT=1.05
LOSS_STREAK_THRESHOLD=2
LOSS_STREAK_COOLDOWN_HOURS=24

# ── LIVE TRADING (real money - leave LIVE_TRADING unset/false until ready) ──
LIVE_TRADING=false
LIVE_EXCHANGES=
PER_EXCHANGE_CAPITAL_USD=20
KILL_SWITCH=false
LEG_FILL_RETRY_SECS=5

# Aster credentials - only needed once LIVE_TRADING=true and "aster" is in
# LIVE_EXCHANGES. Set these as actual secrets in Railway's Variables tab,
# never commit real values here.
ASTER_API_KEY=
ASTER_API_SECRET=
